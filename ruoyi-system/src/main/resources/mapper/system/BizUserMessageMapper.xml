<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizUserMessageMapper">

	<resultMap type="BizUserMessage" id="BizUserMessageResult">
		<id     property="messageId"       column="message_id"       />
		<result property="userId"          column="user_id"          />
		<result property="title"           column="title"            />
		<result property="content"         column="content"          />
		<result property="isRead"          column="is_read"          />
		<result property="readTime"        column="read_time"        />
		<result property="sendBy"          column="send_by"          />
		<result property="sendTime"        column="send_time"        />
		<result property="createBy"        column="create_by"        />
		<result property="createTime"      column="create_time"      />
		<result property="updateBy"        column="update_by"        />
		<result property="updateTime"      column="update_time"      />
		<result property="remark"          column="remark"           />
	</resultMap>

	<sql id="selectBizUserMessageVo">
		select message_id, user_id, title, content,
		       is_read, read_time, send_by, send_time,
		       create_by, create_time, update_by, update_time, remark
		from biz_user_message
	</sql>

	<select id="selectBizUserMessageList" parameterType="BizUserMessage" resultMap="BizUserMessageResult">
		<include refid="selectBizUserMessageVo"/>
		<where>
			<if test="userId != null">
				AND user_id = #{userId}
			</if>
			<if test="title != null and title != ''">
				AND title like concat('%', #{title}, '%')
			</if>
			<if test="isRead != null and isRead != ''">
				AND is_read = #{isRead}
			</if>
			<if test="sendBy != null and sendBy != ''">
				AND send_by like concat('%', #{sendBy}, '%')
			</if>
		</where>
		order by create_time desc
	</select>

	<select id="selectBizUserMessageById" parameterType="Long" resultMap="BizUserMessageResult">
		<include refid="selectBizUserMessageVo"/>
		where message_id = #{messageId}
	</select>

	<select id="countUnreadByUserId" parameterType="Long" resultType="int">
		select count(*) from biz_user_message where user_id = #{userId} and is_read = '0'
	</select>

	<insert id="insertBizUserMessage" parameterType="BizUserMessage" useGeneratedKeys="true" keyProperty="messageId">
		insert into biz_user_message(
			<if test="userId != null">user_id,</if>
			<if test="title != null and title != ''">title,</if>
			<if test="content != null and content != ''">content,</if>
			<if test="isRead != null and isRead != ''">is_read,</if>
			<if test="readTime != null">read_time,</if>
			<if test="sendBy != null and sendBy != ''">send_by,</if>
			<if test="sendTime != null">send_time,</if>
			<if test="createBy != null and createBy != ''">create_by,</if>
			<if test="remark != null and remark != ''">remark,</if>
			create_time
		)values(
			<if test="userId != null">#{userId},</if>
			<if test="title != null and title != ''">#{title},</if>
			<if test="content != null and content != ''">#{content},</if>
			<if test="isRead != null and isRead != ''">#{isRead},</if>
			<if test="readTime != null">#{readTime},</if>
			<if test="sendBy != null and sendBy != ''">#{sendBy},</if>
			<if test="sendTime != null">#{sendTime},</if>
			<if test="createBy != null and createBy != ''">#{createBy},</if>
			<if test="remark != null and remark != ''">#{remark},</if>
			sysdate()
		)
	</insert>

	<update id="updateBizUserMessage" parameterType="BizUserMessage">
 		update biz_user_message
 		<set>
 			<if test="userId != null">user_id = #{userId},</if>
 			<if test="title != null">title = #{title},</if>
 			<if test="content != null">content = #{content},</if>
 			<if test="isRead != null and isRead != ''">is_read = #{isRead},</if>
 			<if test="readTime != null">read_time = #{readTime},</if>
 			<if test="sendBy != null">send_by = #{sendBy},</if>
 			<if test="sendTime != null">send_time = #{sendTime},</if>
 			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
 			<if test="remark != null">remark = #{remark},</if>
 			update_time = sysdate()
 		</set>
 		where message_id = #{messageId}
	</update>

	<delete id="deleteBizUserMessageById" parameterType="Long">
		delete from biz_user_message where message_id = #{messageId}
	</delete>

	<delete id="deleteBizUserMessageByIds" parameterType="Long">
 		delete from biz_user_message where message_id in
 		<foreach collection="array" item="messageId" open="(" separator="," close=")">
 			#{messageId}
        </foreach>
 	</delete>

</mapper>
