<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizPhonebookMapper">

    <resultMap type="BizPhonebook" id="BizPhonebookResult">
        <id     property="phonebookId"      column="phonebook_id"       />
        <result property="merchantName"     column="merchant_name"      />
        <result property="ownerName"        column="owner_name"         />
        <result property="phone"            column="phone"              />
        <result property="phone1"           column="phone1"            />
        <result property="phone2"           column="phone2"            />
        <result property="category"         column="category"           />
        <result property="address"          column="address"            />
        <result property="businessLicense"  column="business_license"   />
        <result property="status"           column="status"             />
        <result property="validUntil"       column="valid_until"        />
        <result property="createBy"         column="create_by"          />
        <result property="createTime"       column="create_time"        />
        <result property="updateBy"         column="update_by"          />
        <result property="updateTime"       column="update_time"        />
        <result property="remark"           column="remark"             />
    </resultMap>

    <sql id="selectBizPhonebookVo">
        select phonebook_id, merchant_name, owner_name, phone, phone1, phone2, category, address, business_license,
            status, valid_until, create_by, create_time, update_by, update_time, remark
        from biz_phonebook
    </sql>

    <select id="selectBizPhonebookList" parameterType="BizPhonebook" resultMap="BizPhonebookResult">
        <include refid="selectBizPhonebookVo"/>
        <where>
            <if test="merchantName != null and merchantName != ''">
                AND merchant_name like concat('%', #{merchantName}, '%')
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="phone != null and phone != ''">
                AND (phone1 like concat('%', #{phone}, '%') OR phone2 like concat('%', #{phone}, '%'))
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

    <select id="selectBizPhonebookById" parameterType="Long" resultMap="BizPhonebookResult">
        <include refid="selectBizPhonebookVo"/>
        where phonebook_id = #{phonebookId}
    </select>

    <insert id="insertBizPhonebook" parameterType="BizPhonebook" useGeneratedKeys="true" keyProperty="phonebookId">
        insert into biz_phonebook(
            <if test="merchantName != null and merchantName != ''">merchant_name,</if>
            <if test="ownerName != null and ownerName != ''">owner_name,</if>
            phone,
            phone1,
            phone2,
            <if test="category != null and category != ''">category,</if>
            <if test="address != null and address != ''">address,</if>
            <if test="businessLicense != null and businessLicense != ''">business_license,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="validUntil != null">valid_until,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="merchantName != null and merchantName != ''">#{merchantName},</if>
            <if test="ownerName != null and ownerName != ''">#{ownerName},</if>
            #{phone},
            #{phone1},
            #{phone2},
            <if test="category != null and category != ''">#{category},</if>
            <if test="address != null and address != ''">#{address},</if>
            <if test="businessLicense != null and businessLicense != ''">#{businessLicense},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="validUntil != null">#{validUntil},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateBizPhonebook" parameterType="BizPhonebook">
        update biz_phonebook
        <set>
            <if test="merchantName != null and merchantName != ''">merchant_name = #{merchantName},</if>
            <if test="ownerName != null and ownerName != ''">owner_name = #{ownerName},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="phone1 != null">phone1 = #{phone1},</if>
            <if test="phone2 != null">phone2 = #{phone2},</if>
            <if test="category != null and category != ''">category = #{category},</if>
            <if test="address != null">address = #{address},</if>
            <if test="businessLicense != null">business_license = #{businessLicense},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="validUntil != null">valid_until = #{validUntil},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where phonebook_id = #{phonebookId}
    </update>

    <delete id="deleteBizPhonebookById" parameterType="Long">
        delete from biz_phonebook where phonebook_id = #{phonebookId}
    </delete>

    <delete id="deleteBizPhonebookByIds" parameterType="Long">
        delete from biz_phonebook where phonebook_id in
        <foreach collection="array" item="phonebookId" open="(" separator="," close=")">
            #{phonebookId}
        </foreach>
    </delete>

</mapper>
