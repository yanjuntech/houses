<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizMiniappUserMapper">

    <resultMap type="BizMiniappUser" id="BizMiniappUserResult">
        <id     property="userId"          column="user_id"          />
        <result property="phone"           column="phone"            />
        <result property="openid"          column="openid"           />
        <result property="unionId"         column="union_id"         />
        <result property="nickname"        column="nickname"         />
        <result property="avatar"          column="avatar"           />
        <result property="gender"          column="gender"           />
        <result property="userType"        column="user_type"        />
        <result property="verifyStatus"    column="verify_status"    />
        <result property="realName"        column="real_name"        />
        <result property="idCard"          column="id_card"          />
        <result property="status"          column="status"           />
        <result property="wechatNickname"  column="wechat_nickname"  />
        <result property="wechatAvatar"    column="wechat_avatar"    />
        <result property="idCardVerified"  column="id_card_verified" />
        <result property="blacklistReason" column="blacklist_reason" />
        <result property="blacklistTime"   column="blacklist_time"   />
        <result property="loginIp"         column="login_ip"         />
        <result property="loginDate"       column="login_date"       />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
    </resultMap>

    <sql id="selectBizMiniappUserVo">
        select user_id, phone, openid, union_id, nickname, avatar, gender, user_type, verify_status, real_name, id_card, status, wechat_nickname, wechat_avatar, id_card_verified, blacklist_reason, blacklist_time, login_ip, login_date, create_by, create_time, update_by, update_time, remark
        from biz_miniapp_user
    </sql>

    <select id="selectBizMiniappUserList" parameterType="BizMiniappUser" resultMap="BizMiniappUserResult">
        <include refid="selectBizMiniappUserVo"/>
        <where>
            <if test="phone != null and phone != ''">
                AND phone like concat('%', #{phone}, '%')
            </if>
            <if test="nickname != null and nickname != ''">
                AND nickname like concat('%', #{nickname}, '%')
            </if>
            <if test="wechatNickname != null and wechatNickname != ''">
                AND wechat_nickname like concat('%', #{wechatNickname}, '%')
            </if>
            <if test="userType != null and userType != ''">
                AND user_type = #{userType}
            </if>
            <if test="verifyStatus != null and verifyStatus != ''">
                AND verify_status = #{verifyStatus}
            </if>
            <if test="idCardVerified != null and idCardVerified != ''">
                AND id_card_verified = #{idCardVerified}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by user_id desc
    </select>

    <select id="selectBlacklist" parameterType="BizMiniappUser" resultMap="BizMiniappUserResult">
        <include refid="selectBizMiniappUserVo"/>
        <where>
            status = '2'
            <if test="phone != null and phone != ''">
                AND phone like concat('%', #{phone}, '%')
            </if>
            <if test="nickname != null and nickname != ''">
                AND nickname like concat('%', #{nickname}, '%')
            </if>
            <if test="wechatNickname != null and wechatNickname != ''">
                AND wechat_nickname like concat('%', #{wechatNickname}, '%')
            </if>
        </where>
        order by blacklist_time desc
    </select>

    <select id="selectBizMiniappUserByUserId" parameterType="Long" resultMap="BizMiniappUserResult">
        <include refid="selectBizMiniappUserVo"/>
        where user_id = #{userId}
    </select>

    <select id="selectBizMiniappUserByPhone" parameterType="String" resultMap="BizMiniappUserResult">
        <include refid="selectBizMiniappUserVo"/>
        where phone = #{phone} limit 1
    </select>

    <select id="selectBizMiniappUserByOpenid" parameterType="String" resultMap="BizMiniappUserResult">
        <include refid="selectBizMiniappUserVo"/>
        where openid = #{openid} limit 1
    </select>

    <insert id="insertBizMiniappUser" parameterType="BizMiniappUser" useGeneratedKeys="true" keyProperty="userId">
        insert into biz_miniapp_user(
            <if test="userId != null and userId != 0">user_id,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="openid != null and openid != ''">openid,</if>
            <if test="unionId != null and unionId != ''">union_id,</if>
            <if test="nickname != null and nickname != ''">nickname,</if>
            <if test="avatar != null and avatar != ''">avatar,</if>
            <if test="gender != null and gender != ''">gender,</if>
            <if test="userType != null and userType != ''">user_type,</if>
            <if test="verifyStatus != null and verifyStatus != ''">verify_status,</if>
            <if test="realName != null and realName != ''">real_name,</if>
            <if test="idCard != null and idCard != ''">id_card,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="wechatNickname != null and wechatNickname != ''">wechat_nickname,</if>
            <if test="wechatAvatar != null and wechatAvatar != ''">wechat_avatar,</if>
            <if test="idCardVerified != null and idCardVerified != ''">id_card_verified,</if>
            <if test="blacklistReason != null and blacklistReason != ''">blacklist_reason,</if>
            <if test="blacklistTime != null">blacklist_time,</if>
            <if test="loginIp != null and loginIp != ''">login_ip,</if>
            <if test="loginDate != null">login_date,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="userId != null and userId != 0">#{userId},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="openid != null and openid != ''">#{openid},</if>
            <if test="unionId != null and unionId != ''">#{unionId},</if>
            <if test="nickname != null and nickname != ''">#{nickname},</if>
            <if test="avatar != null and avatar != ''">#{avatar},</if>
            <if test="gender != null and gender != ''">#{gender},</if>
            <if test="userType != null and userType != ''">#{userType},</if>
            <if test="verifyStatus != null and verifyStatus != ''">#{verifyStatus},</if>
            <if test="realName != null and realName != ''">#{realName},</if>
            <if test="idCard != null and idCard != ''">#{idCard},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="wechatNickname != null and wechatNickname != ''">#{wechatNickname},</if>
            <if test="wechatAvatar != null and wechatAvatar != ''">#{wechatAvatar},</if>
            <if test="idCardVerified != null and idCardVerified != ''">#{idCardVerified},</if>
            <if test="blacklistReason != null and blacklistReason != ''">#{blacklistReason},</if>
            <if test="blacklistTime != null">#{blacklistTime},</if>
            <if test="loginIp != null and loginIp != ''">#{loginIp},</if>
            <if test="loginDate != null">#{loginDate},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateBizMiniappUser" parameterType="BizMiniappUser">
        update biz_miniapp_user
        <set>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="openid != null and openid != ''">openid = #{openid},</if>
            <if test="unionId != null and unionId != ''">union_id = #{unionId},</if>
            <if test="nickname != null and nickname != ''">nickname = #{nickname},</if>
            <if test="avatar != null and avatar != ''">avatar = #{avatar},</if>
            <if test="gender != null and gender != ''">gender = #{gender},</if>
            <if test="userType != null and userType != ''">user_type = #{userType},</if>
            <if test="verifyStatus != null and verifyStatus != ''">verify_status = #{verifyStatus},</if>
            <if test="realName != null and realName != ''">real_name = #{realName},</if>
            <if test="idCard != null and idCard != ''">id_card = #{idCard},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="wechatNickname != null and wechatNickname != ''">wechat_nickname = #{wechatNickname},</if>
            <if test="wechatAvatar != null and wechatAvatar != ''">wechat_avatar = #{wechatAvatar},</if>
            <if test="idCardVerified != null and idCardVerified != ''">id_card_verified = #{idCardVerified},</if>
            <if test="blacklistReason != null">blacklist_reason = #{blacklistReason},</if>
            <if test="blacklistTime != null">blacklist_time = #{blacklistTime},</if>
            <if test="loginIp != null and loginIp != ''">login_ip = #{loginIp},</if>
            <if test="loginDate != null">login_date = #{loginDate},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where user_id = #{userId}
    </update>

    <update id="updateUserType" parameterType="BizMiniappUser">
        update biz_miniapp_user
        <set>
            <if test="userType != null and userType != ''">user_type = #{userType},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where user_id = #{userId}
    </update>

    <update id="updateVerifyStatus" parameterType="BizMiniappUser">
        update biz_miniapp_user
        <set>
            <if test="verifyStatus != null and verifyStatus != ''">verify_status = #{verifyStatus},</if>
            <if test="realName != null and realName != ''">real_name = #{realName},</if>
            <if test="idCard != null and idCard != ''">id_card = #{idCard},</if>
            <if test="idCardVerified != null and idCardVerified != ''">id_card_verified = #{idCardVerified},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where user_id = #{userId}
    </update>

    <update id="addToBlacklist" parameterType="BizMiniappUser">
        update biz_miniapp_user
        <set>
            status = '2',
            <if test="blacklistReason != null and blacklistReason != ''">blacklist_reason = #{blacklistReason},</if>
            blacklist_time = sysdate(),
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where user_id = #{userId}
    </update>

    <update id="removeFromBlacklist" parameterType="Long">
        update biz_miniapp_user
        <set>
            status = '0',
            blacklist_reason = null,
            blacklist_time = null,
            update_time = sysdate()
        </set>
        where user_id = #{userId}
    </update>

    <delete id="deleteBizMiniappUserByUserId" parameterType="Long">
        delete from biz_miniapp_user where user_id = #{userId}
    </delete>

    <delete id="deleteBizMiniappUserByUserIds" parameterType="Long">
        delete from biz_miniapp_user where user_id in
        <foreach collection="array" item="userId" open="(" separator="," close=")">
            #{userId}
        </foreach>
    </delete>

</mapper>
