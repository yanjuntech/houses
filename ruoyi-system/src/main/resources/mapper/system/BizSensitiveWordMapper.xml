<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizSensitiveWordMapper">

	<resultMap type="BizSensitiveWord" id="BizSensitiveWordResult">
		<id     property="wordId"          column="word_id"          />
		<result property="word"            column="word"             />
		<result property="category"        column="category"         />
		<result property="status"          column="status"           />
		<result property="createBy"        column="create_by"        />
		<result property="createTime"      column="create_time"      />
		<result property="updateBy"        column="update_by"        />
		<result property="updateTime"      column="update_time"      />
		<result property="remark"          column="remark"           />
	</resultMap>

	<sql id="selectBizSensitiveWordVo">
		select word_id, word, category, status, create_by, create_time, update_by, update_time, remark
		from biz_sensitive_word
	</sql>

	<select id="selectBizSensitiveWordList" parameterType="BizSensitiveWord" resultMap="BizSensitiveWordResult">
		<include refid="selectBizSensitiveWordVo"/>
		<where>
			<if test="word != null and word != ''">
				AND word like concat('%', #{word}, '%')
			</if>
			<if test="category != null and category != ''">
				AND category = #{category}
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
		</where>
		order by create_time desc
	</select>

	<select id="selectBizSensitiveWordByWordId" parameterType="Long" resultMap="BizSensitiveWordResult">
		<include refid="selectBizSensitiveWordVo"/>
		where word_id = #{wordId}
	</select>

	<select id="selectAllEnabledWords" resultMap="BizSensitiveWordResult">
		<include refid="selectBizSensitiveWordVo"/>
		where status = '0'
	</select>

	<insert id="insertBizSensitiveWord" parameterType="BizSensitiveWord" useGeneratedKeys="true" keyProperty="wordId">
		insert into biz_sensitive_word(
			<if test="word != null and word != ''">word,</if>
			<if test="category != null and category != ''">category,</if>
			<if test="status != null and status != ''">status,</if>
			<if test="createBy != null and createBy != ''">create_by,</if>
			<if test="remark != null and remark != ''">remark,</if>
			create_time
		)values(
			<if test="word != null and word != ''">#{word},</if>
			<if test="category != null and category != ''">#{category},</if>
			<if test="status != null and status != ''">#{status},</if>
			<if test="createBy != null and createBy != ''">#{createBy},</if>
			<if test="remark != null and remark != ''">#{remark},</if>
			sysdate()
		)
	</insert>

	<update id="updateBizSensitiveWord" parameterType="BizSensitiveWord">
 		update biz_sensitive_word
 		<set>
 			<if test="word != null and word != ''">word = #{word},</if>
 			<if test="category != null and category != ''">category = #{category},</if>
 			<if test="status != null and status != ''">status = #{status},</if>
 			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
 			<if test="remark != null">remark = #{remark},</if>
 			update_time = sysdate()
 		</set>
 		where word_id = #{wordId}
	</update>

	<delete id="deleteBizSensitiveWordByWordId" parameterType="Long">
		delete from biz_sensitive_word where word_id = #{wordId}
	</delete>

	<delete id="deleteBizSensitiveWordByWordIds" parameterType="Long">
 		delete from biz_sensitive_word where word_id in
 		<foreach collection="array" item="wordId" open="(" separator="," close=")">
 			#{wordId}
        </foreach>
 	</delete>

</mapper>
