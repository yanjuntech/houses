<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizBannerMapper">

	<resultMap type="BizBanner" id="BizBannerResult">
		<id     property="bannerId"        column="banner_id"         />
		<result property="image"           column="image"            />
		<result property="title"           column="title"            />
		<result property="content"         column="content"          />
		<result property="validStart"      column="valid_start"       />
		<result property="validEnd"        column="valid_end"         />
		<result property="contactPhone"    column="contact_phone"     />
		<result property="sort"            column="sort"               />
		<result property="status"          column="status"             />
		<result property="createBy"        column="create_by"          />
		<result property="createTime"      column="create_time"        />
		<result property="updateBy"        column="update_by"          />
		<result property="updateTime"      column="update_time"        />
		<result property="remark"          column="remark"             />
	</resultMap>

	<sql id="selectBizBannerVo">
		select banner_id, image, title, content, valid_start, valid_end, contact_phone, sort, status,
		       create_by, create_time, update_by, update_time, remark
		from biz_banner
	</sql>

	<select id="selectBizBannerList" parameterType="BizBanner" resultMap="BizBannerResult">
		<include refid="selectBizBannerVo"/>
		<where>
			<if test="title != null and title != ''">
				AND title like concat('%', #{title}, '%')
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
		</where>
		order by sort asc, create_time desc
	</select>

	<select id="selectBizBannerById" parameterType="Long" resultMap="BizBannerResult">
		<include refid="selectBizBannerVo"/>
		where banner_id = #{bannerId}
	</select>

	<select id="selectValidBannerList" resultMap="BizBannerResult">
		<include refid="selectBizBannerVo"/>
		where status = '0'
		  and (valid_start is null or valid_start &lt;= now())
		  and (valid_end is null or valid_end &gt;= now())
		order by sort asc
	</select>

	<insert id="insertBizBanner" parameterType="BizBanner" useGeneratedKeys="true" keyProperty="bannerId">
		insert into biz_banner(
			<if test="image != null and image != ''">image,</if>
			<if test="title != null and title != ''">title,</if>
			<if test="content != null and content != ''">content,</if>
			<if test="validStart != null">valid_start,</if>
			<if test="validEnd != null">valid_end,</if>
			<if test="contactPhone != null and contactPhone != ''">contact_phone,</if>
			<if test="sort != null">sort,</if>
			<if test="status != null and status != ''">status,</if>
			<if test="createBy != null and createBy != ''">create_by,</if>
			<if test="remark != null and remark != ''">remark,</if>
			create_time
		)values(
			<if test="image != null and image != ''">#{image},</if>
			<if test="title != null and title != ''">#{title},</if>
			<if test="content != null and content != ''">#{content},</if>
			<if test="validStart != null">#{validStart},</if>
			<if test="validEnd != null">#{validEnd},</if>
			<if test="contactPhone != null and contactPhone != ''">#{contactPhone},</if>
			<if test="sort != null">#{sort},</if>
			<if test="status != null and status != ''">#{status},</if>
			<if test="createBy != null and createBy != ''">#{createBy},</if>
			<if test="remark != null and remark != ''">#{remark},</if>
			sysdate()
		)
	</insert>

	<update id="updateBizBanner" parameterType="BizBanner">
 		update biz_banner
 		<set>
 			<if test="image != null and image != ''">image = #{image},</if>
 			<if test="title != null">title = #{title},</if>
 			<if test="content != null">content = #{content},</if>
 			<if test="validStart != null">valid_start = #{validStart},</if>
 			<if test="validEnd != null">valid_end = #{validEnd},</if>
 			<if test="contactPhone != null">contact_phone = #{contactPhone},</if>
 			<if test="sort != null">sort = #{sort},</if>
 			<if test="status != null and status != ''">status = #{status},</if>
 			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
 			<if test="remark != null">remark = #{remark},</if>
 			update_time = sysdate()
 		</set>
 		where banner_id = #{bannerId}
	</update>

	<delete id="deleteBizBannerById" parameterType="Long">
		delete from biz_banner where banner_id = #{bannerId}
	</delete>

	<delete id="deleteBizBannerByIds" parameterType="Long">
 		delete from biz_banner where banner_id in
 		<foreach collection="array" item="bannerId" open="(" separator="," close=")">
 			#{bannerId}
        </foreach>
 	</delete>

</mapper>
